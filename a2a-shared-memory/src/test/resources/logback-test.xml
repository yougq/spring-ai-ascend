<?xml version="1.0" encoding="UTF-8"?>
<!-- Overrides agent-runtime's logback-spring.xml during the e2e test (its
     TRAJECTORY_JSONL appender needs logstash-logback-encoder, which this module
     doesn't ship). A plain console config keeps the booted runtime quiet. -->
<configuration>
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level %logger{24} - %msg%n</pattern>
    </encoder>
  </appender>
  <root level="WARN">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
