<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.huawei.ascend.examples</groupId>
        <artifactId>travel-parent</artifactId>
        <version>0.2.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>agent-travel-trip</artifactId>
    <packaging>jar</packaging>

    <name>agent-travel-trip</name>
    <description>差旅行程规划智能体（ReAct 单体 + 唯一工具 plan_hotel）</description>

    <dependencies>
        <!-- openJiuwen agent 框架（version 由 travel-parent 管理）。 -->
        <dependency>
            <groupId>com.openjiuwen</groupId>
            <artifactId>agent-core-java</artifactId>
        </dependency>

        <!--
          酒店规划子智能体：runtime scope —— agent-trip 通过反射（ReflectiveHotelPlannerClient）
          装配 agent-hotel，编译期不依赖其任何类型；仅运行时 classpath 需要它。
          version 由 travel-parent 管理为 ${project.version}（与本模块同为 0.1.0-SNAPSHOT）。
        -->
        <dependency>
            <groupId>com.huawei.ascend.examples</groupId>
            <artifactId>agent-travel-hotel</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- Test (version managed by Spring Boot BOM). -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- 单元测试：*Test，CI 无 LLM Key 也能跑 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>**/*Test.java</include>
                    </includes>
                </configuration>
            </plugin>

            <!-- 集成测试：*IT，真调 LLM，可 -DskipITs 跳过 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- 跑 Sample：mvn exec:java -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.2.0</version>
                <configuration>
                    <mainClass>com.huawei.ascend.examples.trip.TripSampleMain</mainClass>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
