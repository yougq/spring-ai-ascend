# Copy to .env and fill in. Never commit .env.
#
# The MemOpt engine is delivered as a CLOSED container image — pull it from your
# registry (its Python source + Dockerfile live in the MemOpt repo, not here).
MEMOPT_IMAGE=memopt:0.0.1
# MEMOPT_IMAGE=registry.example.com/your-namespace/memopt:0.0.1

# --- required: the LLM gateway the MemOpt engine calls ---
GATEWAY_BASE_URL=
GATEWAY_API_KEY=
DEFAULT_MODEL=

# --- optional ---
CHROMA_EMBEDDING_MODEL=
MEMOPT_JUDGE_MODEL=
MEMOPT_PORT=8077

# Gate /v1/* behind a bearer token (recommended whenever MemOpt is reachable beyond
# localhost). The A2A kit MUST send the same token — see ENABLE_MEMOPT.md.
MEMOPT_FACADE_AUTH_TOKEN=
